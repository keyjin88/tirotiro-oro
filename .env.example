# Шаблон для production на VPS (Reg.ru и аналоги).
# Скопируйте на сервер: scp .env.example root@HOST:/opt/tirotiro-oro/.env
# chmod 600 .env — не коммитьте .env в git.

POSTGRES_DB=equipment
POSTGRES_USER=equipment_app
POSTGRES_PASSWORD=change-me-strong

SPRING_LIQUIBASE_CONTEXTS=

APP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
APP_BOOTSTRAP_ADMIN_PASSWORD=change-me-strong
APP_BOOTSTRAP_ADMIN_NAME=Admin

# Host port mapped to app container 8080 (use 80 only if nothing else binds 80)
APP_HTTP_PORT=8080
